# ─── Database ───────────────────────────────────────────
POSTGRES_USER=ems_admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ems_claims
DATABASE_URL=postgresql+asyncpg://ems_admin:CHANGE_ME@postgres:5432/ems_claims

# ─── RabbitMQ ───────────────────────────────────────────
RABBITMQ_USER=ems_rabbit
RABBITMQ_PASS=CHANGE_ME
CELERY_BROKER_URL=amqp://ems_rabbit:CHANGE_ME@rabbitmq:5672//

# ─── JWT Auth ───────────────────────────────────────────
SECRET_KEY=CHANGE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ─── Claid.ai Image Preprocessing ──────────────────────
CLAID_API_KEY=CHANGE_ME

# ─── LlamaParse (Vision-Language AI OCR) ────────────────
LLAMA_CLOUD_API_KEY=CHANGE_ME

# ─── Mistral OCR (Backup) ──────────────────────────────
MISTRAL_API_KEY=CHANGE_ME

# ─── File Storage ───────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# ─── CORS ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── POPIA Compliance ──────────────────────────────────
ENCRYPTION_KEY=CHANGE_ME
