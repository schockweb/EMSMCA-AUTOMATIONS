# ═══════════════════════════════════════════════════════════════════════════
# EMS Claims Portal — Backend Environment Variables
# Copy to .env and fill in real values before deployment.
#
# ⚠️  NEVER commit .env to version control. Only .env.example is tracked.
# ═══════════════════════════════════════════════════════════════════════════


# ─── Environment ─────────────────────────────────────────────────────────
# "development" enables debug mode, verbose logging, Swagger UI.
# "production" enforces stricter security, JSON logging.
APP_ENV=production


# ─── Database ────────────────────────────────────────────────────────────
# Async driver (asyncpg) for FastAPI's async ORM queries.
# In production, point to PgBouncer (port 6432) instead of direct Postgres.
DATABASE_URL=postgresql+asyncpg://ems_admin:CHANGE_ME@localhost:6432/ems_claims

# Connection pool tuning (per Uvicorn worker process):
#   pool_size × num_workers = persistent connections per backend replica
#   max_overflow provides burst headroom above pool_size
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800


# ─── RabbitMQ / Celery ──────────────────────────────────────────────────
# AMQP broker URL for Celery task queue
CELERY_BROKER_URL=amqp://ems_rabbit:CHANGE_ME@rabbitmq:5672//


# ─── JWT Authentication ─────────────────────────────────────────────────
# SECRET_KEY: Used to sign JWT tokens.  Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# ⚠️  REQUIRED — app will refuse to start without this.
SECRET_KEY=CHANGE_ME_GENERATE_A_SECURE_KEY

# JWT algorithm and token lifetimes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7


# ─── POPIA Encryption ───────────────────────────────────────────────────
# Fernet key for encrypting PII fields at rest (POPIA compliance).
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️  REQUIRED — app will refuse to start without this.
ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_FERNET_KEY


# ─── CORS / URLs ────────────────────────────────────────────────────────
# Frontend URL for CORS origin allowlist
FRONTEND_URL=https://app.example.co.za

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://app.example.co.za

# Public URL used in outbound emails (e.g. doctor portal links)
# Must be the externally-reachable URL, not an internal Docker hostname.
PUBLIC_APP_URL=https://app.example.co.za


# ─── File Storage ───────────────────────────────────────────────────────
# Directory for uploaded PRF scans and documents
UPLOAD_DIR=/app/uploads

# Maximum upload file size in megabytes
MAX_UPLOAD_SIZE_MB=50


# ─── Feature Flags ──────────────────────────────────────────────────────
# OCR / paper-PRF intake — disabled during Digital PRF rollout phase
OCR_INTAKE_ENABLED=false


# ─── Claid.ai (Image Preprocessing) ─────────────────────────────────────
CLAID_API_KEY=


# ─── Azure AI Document Intelligence ─────────────────────────────────────
AZURE_DOC_INTEL_ENDPOINT=
AZURE_DOC_INTEL_KEY=


# ─── Azure OpenAI ───────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview


# ─── LlamaParse (Vision-Language AI OCR) ─────────────────────────────────
LLAMA_CLOUD_API_KEY=


# ─── Outbound Email (SMTP) ──────────────────────────────────────────────
# Used for:
#   - Sending Digital PRFs to receiving doctors
#   - Password reset emails
#   - Alert notifications
# If SMTP_HOST is empty, email endpoints gracefully no-op.
SMTP_HOST=smtp.example.co.za
SMTP_PORT=587
SMTP_USERNAME=noreply@app.example.co.za
SMTP_PASSWORD=CHANGE_ME
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@app.example.co.za
SMTP_FROM_NAME=EMS Claims Portal


# ─── Notifications (SMS) ────────────────────────────────────────────────
# Infobip — primary SMS provider
INFOBIP_API_KEY=
INFOBIP_BASE_URL=https://api.infobip.com

# Twilio — fallback SMS provider
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=


# ─── Logging ────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: "text" (human-readable) or "json" (structured, for Loki/ELK)
LOG_FORMAT=json


# ─── Docker Compose Variables ───────────────────────────────────────────
# These are used by docker-compose.prod.yml for service containers
POSTGRES_USER=ems_admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ems_claims
RABBITMQ_USER=ems_rabbit
RABBITMQ_PASS=CHANGE_ME


# ─── Monitoring ─────────────────────────────────────────────────────────
# Grafana admin password (used in docker-compose.monitoring.yml)
GRAFANA_ADMIN_PASSWORD=CHANGE_ME


# ─── Scheme Credentials (per-scheme B2B API config) ─────────────────────
# Example for GEMS medical scheme:
# SCHEME_GEMS_BASE_URL=https://api.gems.gov.za/b2b/v1
# SCHEME_GEMS_CLIENT_ID=my-client-id
# SCHEME_GEMS_CLIENT_SECRET=my-secret
# SCHEME_GEMS_ENVIRONMENT=sandbox
# SCHEME_GEMS_INTEGRATION_TYPE=generic
# SCHEME_GEMS_OAUTH_TOKEN_URL=https://api.gems.gov.za/oauth/token
# SCHEME_GEMS_PROVIDER_PRACTICE=009003074661
# SCHEME_GEMS_PAYER_TYPE=SCHEME
# SCHEME_GEMS_CONTACT_EMAIL=auth@gems.gov.za
# SCHEME_GEMS_MATCH_KEYWORDS=gems,government employees
# SCHEME_GEMS_EXTRA_HEADERS_JSON={"X-Practice-Type": "EMS"}
